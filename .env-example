# Copy this file to .env and fill in the values for your local environment.
# .env is gitignored; .env-example is committed as a reference.

# ---------------------------------------------------------------------------
# OSM API credentials
# Required for functional API upload tests (testScriptApiV3).
# Register a dev account at https://api06.dev.openstreetmap.org
# ---------------------------------------------------------------------------
OSM_DEV_API_PASSWORD=

# ---------------------------------------------------------------------------
# AWS credentials
# Required only when publishing the plugin JAR to S3
# (./gradlew publishToAws). Not needed for normal development or testing.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# JVM options
# Increase heap if the build or tests run out of memory.
# ---------------------------------------------------------------------------
JAVA_OPTS=-Xmx4G

# ---------------------------------------------------------------------------
# GitHub token authorized to manage releases in the repository
# josm-scripting-plugin
GITHUB_ACCESS_TOKEN=
